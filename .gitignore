# Per-session ephemeral state written by bug-fixer + chatgpt-* agents
# (review-mode keyword propagation across sub-agent dispatches).
# Must never be committed.
.claude/session-state/

# Node + tooling artefacts when developing inside the framework repo itself.
node_modules/
*.log
.chatgpt-diffs/

*.framework-new

# Session-generated code-intelligence artifacts, produced by
# .claude/hooks/code-graph-freshness-check.js at session start (and by the
# dev-server watcher). Consumer-repo files per
# scripts/validate-framework-allowlist.json — never framework sources.
references/.code-graph-cache.json
references/.watcher.pid
references/import-graph/
references/project-map.md
